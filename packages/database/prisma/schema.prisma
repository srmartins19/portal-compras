// BidFlow — Prisma Schema
// Multi-tenant procurement platform
// ==============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum UserRole {
  ADMIN
  BUYER
  APPROVER
  SUPPLIER
}

enum RfqStatus {
  DRAFT
  OPEN
  ANALYSIS
  CLOSED
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  RECEIVED
  CANCELLED
}

enum BillingPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum AuditAction {
  RFQ_CREATED
  RFQ_OPENED
  RFQ_CLOSED
  BID_SUBMITTED
  BID_UPDATED
  ORDER_CREATED
  ORDER_APPROVED
  ORDER_SENT
  ORDER_RECEIVED
  SUPPLIER_INVITED
  SUPPLIER_REGISTERED
  USER_CREATED
  USER_UPDATED
}

// ──────────────────────────────────────────────
// COMPANIES (tenants)
// ──────────────────────────────────────────────

model Company {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  taxId       String?     @map("tax_id")
  email       String
  phone       String?
  website     String?
  logoUrl     String?     @map("logo_url")
  plan        BillingPlan @default(BASIC)
  stripeCustomerId String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  users       User[]
  suppliers   Supplier[]
  items       Item[]
  rfqs        Rfq[]
  orders      Order[]
  auditLogs   AuditLog[]
  metrics     ProcurementMetric[]

  @@map("companies")
}

// ──────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(BUYER)
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id])
  rfqsCreated  Rfq[]    @relation("RfqCreatedBy")
  ordersCreated Order[] @relation("OrderCreatedBy")
  ordersApproved Order[] @relation("OrderApprovedBy")
  auditLogs    AuditLog[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

// ──────────────────────────────────────────────
// SUPPLIERS
// ──────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  name         String
  email        String
  phone        String?
  taxId        String?  @map("tax_id")
  website      String?
  contactName  String?  @map("contact_name")
  country      String?
  categories   String[] // item categories
  isActive     Boolean  @default(true) @map("is_active")
  isApproved   Boolean  @default(false) @map("is_approved")
  portalAccess Boolean  @default(false) @map("portal_access")
  passwordHash String?  @map("password_hash") // for portal login
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id])
  bids         Bid[]
  rfqInvites   RfqSupplier[]
  orders       Order[]
  priceHistory PriceHistory[]
  performance  SupplierPerformance?

  @@index([companyId])
  @@index([email])
  @@map("suppliers")
}

// ──────────────────────────────────────────────
// ITEMS (procurement catalog)
// ──────────────────────────────────────────────

model Item {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  code         String?
  name         String
  description  String?
  category     String?
  unit         String   @default("UN") // UN, KG, L, M, etc.
  lastPrice    Decimal? @map("last_price") @db.Decimal(15, 2)
  currency     String   @default("BRL")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company      Company  @relation(fields: [companyId], references: [id])
  rfqItems     RfqItem[]
  priceHistory PriceHistory[]

  @@index([companyId])
  @@index([companyId, category])
  @@map("items")
}

// ──────────────────────────────────────────────
// RFQs
// ──────────────────────────────────────────────

model Rfq {
  id              String    @id @default(cuid())
  companyId       String    @map("company_id")
  createdById     String    @map("created_by_id")
  number          String    // auto-generated: RFQ-2024-0001
  title           String
  description     String?
  status          RfqStatus @default(DRAFT)
  deadline        DateTime
  deliveryDate    DateTime? @map("delivery_date")
  deliveryAddress String?   @map("delivery_address")
  paymentTerms    String?   @map("payment_terms")
  notes           String?

  // Auction settings
  auctionEnabled  Boolean   @default(false) @map("auction_enabled")
  auctionStartTime DateTime? @map("auction_start_time")
  auctionEndTime  DateTime? @map("auction_end_time")

  // Metadata
  currency        String    @default("BRL")
  totalEstimated  Decimal?  @map("total_estimated") @db.Decimal(15, 2)
  winningSupplierId String? @map("winning_supplier_id")
  closedAt        DateTime? @map("closed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company         Company   @relation(fields: [companyId], references: [id])
  createdBy       User      @relation("RfqCreatedBy", fields: [createdById], references: [id])
  items           RfqItem[]
  suppliers       RfqSupplier[]
  bids            Bid[]
  orders          Order[]
  auditLogs       AuditLog[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([number])
  @@map("rfqs")
}

model RfqItem {
  id          String   @id @default(cuid())
  rfqId       String   @map("rfq_id")
  itemId      String?  @map("item_id")
  name        String
  description String?
  quantity    Decimal  @db.Decimal(15, 3)
  unit        String   @default("UN")
  estimatedPrice Decimal? @map("estimated_price") @db.Decimal(15, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  item        Item?    @relation(fields: [itemId], references: [id])
  bidItems    BidItem[]

  @@index([rfqId])
  @@map("rfq_items")
}

model RfqSupplier {
  id          String   @id @default(cuid())
  rfqId       String   @map("rfq_id")
  supplierId  String   @map("supplier_id")
  invitedAt   DateTime @default(now()) @map("invited_at")
  viewedAt    DateTime? @map("viewed_at")
  respondedAt DateTime? @map("responded_at")

  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@unique([rfqId, supplierId])
  @@index([rfqId])
  @@map("rfq_suppliers")
}

// ──────────────────────────────────────────────
// BIDS
// ──────────────────────────────────────────────

model Bid {
  id           String   @id @default(cuid())
  rfqId        String   @map("rfq_id")
  supplierId   String   @map("supplier_id")
  totalPrice   Decimal  @map("total_price") @db.Decimal(15, 2)
  currency     String   @default("BRL")
  deliveryDays Int      @map("delivery_days")
  paymentTerms String?  @map("payment_terms")
  warranty     String?
  notes        String?
  isWinner     Boolean  @default(false) @map("is_winner")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  rfq          Rfq      @relation(fields: [rfqId], references: [id])
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  items        BidItem[]

  @@unique([rfqId, supplierId])
  @@index([rfqId])
  @@index([supplierId])
  @@map("bids")
}

model BidItem {
  id          String   @id @default(cuid())
  bidId       String   @map("bid_id")
  rfqItemId   String   @map("rfq_item_id")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(15, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(15, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  bid         Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  rfqItem     RfqItem  @relation(fields: [rfqItemId], references: [id])

  @@index([bidId])
  @@map("bid_items")
}

// ──────────────────────────────────────────────
// ORDERS
// ──────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  companyId     String      @map("company_id")
  rfqId         String?     @map("rfq_id")
  supplierId    String      @map("supplier_id")
  createdById   String      @map("created_by_id")
  approvedById  String?     @map("approved_by_id")
  number        String      // PO-2024-0001
  status        OrderStatus @default(DRAFT)
  totalAmount   Decimal     @map("total_amount") @db.Decimal(15, 2)
  currency      String      @default("BRL")
  paymentTerms  String?     @map("payment_terms")
  deliveryDate  DateTime?   @map("delivery_date")
  deliveryAddress String?   @map("delivery_address")
  notes         String?
  approvedAt    DateTime?   @map("approved_at")
  sentAt        DateTime?   @map("sent_at")
  receivedAt    DateTime?   @map("received_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  company       Company     @relation(fields: [companyId], references: [id])
  rfq           Rfq?        @relation(fields: [rfqId], references: [id])
  supplier      Supplier    @relation(fields: [supplierId], references: [id])
  createdBy     User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  approvedBy    User?       @relation("OrderApprovedBy", fields: [approvedById], references: [id])

  @@index([companyId])
  @@index([companyId, status])
  @@index([number])
  @@map("orders")
}

// ──────────────────────────────────────────────
// PROCUREMENT INTELLIGENCE
// ──────────────────────────────────────────────

model PriceHistory {
  id         String   @id @default(cuid())
  itemId     String   @map("item_id")
  supplierId String   @map("supplier_id")
  rfqId      String?  @map("rfq_id")
  price      Decimal  @db.Decimal(15, 2)
  currency   String   @default("BRL")
  date       DateTime @default(now())

  item       Item     @relation(fields: [itemId], references: [id])
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@index([itemId])
  @@index([supplierId])
  @@index([itemId, date])
  @@map("price_history")
}

model SupplierPerformance {
  id             String   @id @default(cuid())
  supplierId     String   @unique @map("supplier_id")
  deliveryScore  Float    @default(0) @map("delivery_score")  // 0-10
  qualityScore   Float    @default(0) @map("quality_score")
  priceScore     Float    @default(0) @map("price_score")
  serviceScore   Float    @default(0) @map("service_score")
  overallScore   Float    @default(0) @map("overall_score")
  totalOrders    Int      @default(0) @map("total_orders")
  onTimeOrders   Int      @default(0) @map("on_time_orders")
  updatedAt      DateTime @updatedAt @map("updated_at")

  supplier       Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_performance")
}

model ProcurementMetric {
  id              String   @id @default(cuid())
  companyId       String   @map("company_id")
  month           DateTime // first day of the month
  rfqsCreated     Int      @default(0) @map("rfqs_created")
  ordersCreated   Int      @default(0) @map("orders_created")
  totalSpend      Decimal  @default(0) @map("total_spend") @db.Decimal(15, 2)
  totalSavings    Decimal  @default(0) @map("total_savings") @db.Decimal(15, 2)
  avgCycleTimeDays Float   @default(0) @map("avg_cycle_time_days")
  supplierCount   Int      @default(0) @map("supplier_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, month])
  @@index([companyId])
  @@map("procurement_metrics")
}

// ──────────────────────────────────────────────
// AUDIT LOGS
// ──────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String      @map("company_id")
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  metadata   Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  company    Company     @relation(fields: [companyId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
